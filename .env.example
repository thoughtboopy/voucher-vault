# Environment Variables for Voucher Vault
# Copy this file to .env.local and fill in your values

# ===============================
# Authentication
# ===============================
# Simple passcode for the gateway (change this!)
GATEWAY_PASSCODE=1234

# ===============================
# LINE Notify (Optional - for redemption notifications)
# ===============================
# Get your LINE Notify token from https://notify-bot.line.me/
LINE_NOTIFY_TOKEN=

# ===============================
# EmailJS (Optional - for email notifications)
# ===============================
# Get your EmailJS credentials from https://www.emailjs.com/
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_USER_ID=

# ===============================
# Supabase (Optional - for full-stack database)
# ===============================
# Get your Supabase credentials from https://supabase.com/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===============================
# App Settings
# ===============================
NEXT_PUBLIC_APP_NAME="Your Collection"
PARTNER_NAME="My Love"
